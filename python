#!/usr/bin/env python3
"""
flash_forge.py - Флеш-карточки на Python (CLI + Tkinter GUI)
Поддерживает: CRUD, категории, интервальное повторение (Лейтнер), статистику.
"""
import argparse
import sys
import json
import os
import random
import csv
from datetime import datetime, date, timedelta
from typing import List, Dict, Optional, Tuple
from dataclasses import dataclass, asdict, field

try:
    import tkinter as tk
    from tkinter import ttk, filedialog, messagebox, scrolledtext
    GUI_AVAILABLE = True
except ImportError:
    GUI_AVAILABLE = False

DATA_FILE = "flashcards.json"
STATS_FILE = "flash_stats.json"

@dataclass
class FlashCard:
    id: int
    question: str
    answer: str
    category: str
    box: int = 1                 # 1-5 (система Лейтнера)
    next_review: str = ""        # дата следующего повторения
    created: str = ""
    correct_count: int = 0
    wrong_count: int = 0

class FlashForge:
    def __init__(self, data_file=DATA_FILE, stats_file=STATS_FILE):
        self.data_file = data_file
        self.stats_file = stats_file
        self.cards: List[FlashCard] = []
        self.next_id = 1
        self.load()

    def load(self):
        if os.path.exists(self.data_file):
            try:
                with open(self.data_file, 'r', encoding='utf-8') as f:
                    data = json.load(f)
                    self.cards = [FlashCard(**c) for c in data]
                    self.next_id = max([c.id for c in self.cards], default=0) + 1
            except:
                self.cards = []
                self.next_id = 1
        else:
            self.cards = []
            self.next_id = 1

    def save(self):
        with open(self.data_file, 'w', encoding='utf-8') as f:
            json.dump([asdict(c) for c in self.cards], f, indent=2, ensure_ascii=False)

    def add_card(self, question: str, answer: str, category: str = "General") -> FlashCard:
        card = FlashCard(
            id=self.next_id,
            question=question,
            answer=answer,
            category=category or "General",
            box=1,
            next_review=date.today().isoformat(),
            created=datetime.now().isoformat()
        )
        self.cards.append(card)
        self.next_id += 1
        self.save()
        return card

    def edit_card(self, card_id: int, question: str = None, answer: str = None, category: str = None) -> bool:
        for c in self.cards:
            if c.id == card_id:
                if question: c.question = question
                if answer: c.answer = answer
                if category: c.category = category
                self.save()
                return True
        return False

    def delete_card(self, card_id: int) -> bool:
        for i, c in enumerate(self.cards):
            if c.id == card_id:
                del self.cards[i]
                self.save()
                return True
        return False

    def get_cards_for_review(self, count: int = 10) -> List[FlashCard]:
        """Получить карточки для повторения (по системе Лейтнера)"""
        today = date.today().isoformat()
        # Карточки, готовые к повторению
        ready = [c for c in self.cards if c.next_review <= today]
        if not ready:
            return []
        # Сортируем по коробке (чем выше бокс, тем реже нужно повторять)
        ready.sort(key=lambda x: x.box)
        return random.sample(ready, min(count, len(ready)))

    def update_card_after_review(self, card_id: int, correct: bool):
        for c in self.cards:
            if c.id == card_id:
                if correct:
                    c.correct_count += 1
                    # Перемещаем в следующую коробку (макс. 5)
                    c.box = min(c.box + 1, 5)
                    # Интервалы: 1 день, 3 дня, 7 дней, 14 дней, 30 дней
                    intervals = [1, 3, 7, 14, 30]
                    c.next_review = (date.today() + timedelta(days=intervals[c.box-1])).isoformat()
                else:
                    c.wrong_count += 1
                    # Возвращаем в коробку 1
                    c.box = 1
                    c.next_review = date.today().isoformat()
                self.save()
                return

    def get_statistics(self) -> Dict:
        total = len(self.cards)
        if total == 0:
            return {'total': 0, 'correct': 0, 'wrong': 0, 'avg_correct': 0, 'by_box': {}}
        correct = sum(c.correct_count for c in self.cards)
        wrong = sum(c.wrong_count for c in self.cards)
        by_box = {}
        for i in range(1, 6):
            by_box[i] = len([c for c in self.cards if c.box == i])
        return {
            'total': total,
            'correct': correct,
            'wrong': wrong,
            'avg_correct': correct / total if correct > 0 else 0,
            'by_box': by_box
        }

    def get_categories(self) -> List[str]:
        return sorted(set(c.category for c in self.cards))

    def get_cards_by_category(self, category: str) -> List[FlashCard]:
        return [c for c in self.cards if c.category == category]

    def export_csv(self, filepath: str):
        with open(filepath, 'w', newline='', encoding='utf-8') as f:
            writer = csv.writer(f)
            writer.writerow(["ID", "Question", "Answer", "Category", "Box", "Next Review", "Created", "Correct", "Wrong"])
            for c in self.cards:
                writer.writerow([c.id, c.question, c.answer, c.category, c.box, c.next_review, c.created, c.correct_count, c.wrong_count])

    def import_csv(self, filepath: str):
        with open(filepath, 'r', encoding='utf-8') as f:
            reader = csv.DictReader(f)
            for row in reader:
                self.add_card(row['Question'], row['Answer'], row.get('Category', 'General'))

# ========== CLI ==========
def cli():
    parser = argparse.ArgumentParser(description="Флеш-карточки")
    subparsers = parser.add_subparsers(dest="command", help="Команды")

    # add
    add_parser = subparsers.add_parser("add", help="Добавить карточку")
    add_parser.add_argument("question", help="Вопрос")
    add_parser.add_argument("answer", help="Ответ")
    add_parser.add_argument("--category", "-c", default="General", help="Категория")

    # list
    list_parser = subparsers.add_parser("list", help="Список карточек")
    list_parser.add_argument("--category", "-c", help="Фильтр по категории")

    # study
    study_parser = subparsers.add_parser("study", help="Начать изучение")
    study_parser.add_argument("--count", type=int, default=10, help="Количество карточек")
    study_parser.add_argument("--category", "-c", help="Категория")

    # stats
    stats_parser = subparsers.add_parser("stats", help="Статистика")

    # edit
    edit_parser = subparsers.add_parser("edit", help="Редактировать карточку")
    edit_parser.add_argument("--id", type=int, required=True, help="ID карточки")
    edit_parser.add_argument("--question", help="Новый вопрос")
    edit_parser.add_argument("--answer", help="Новый ответ")
    edit_parser.add_argument("--category", help="Новая категория")

    # delete
    delete_parser = subparsers.add_parser("delete", help="Удалить карточку")
    delete_parser.add_argument("--id", type=int, required=True, help="ID карточки")

    # export
    export_parser = subparsers.add_parser("export", help="Экспорт в CSV")
    export_parser.add_argument("--output", "-o", required=True, help="Имя CSV файла")

    # import
    import_parser = subparsers.add_parser("import", help="Импорт из CSV")
    import_parser.add_argument("--file", "-f", required=True, help="CSV файл")

    # gui
    parser.add_argument("--gui", action="store_true", help="Запустить GUI")
    args = parser.parse_args()

    if args.gui and GUI_AVAILABLE:
        root = tk.Tk()
        app = FlashForgeGUI(root)
        root.mainloop()
        return

    forge = FlashForge()
    if args.command == "add":
        card = forge.add_card(args.question, args.answer, args.category)
        print(f"✅ Карточка #{card.id} добавлена")
    elif args.command == "list":
        cards = forge.get_cards_by_category(args.category) if args.category else forge.cards
        if not cards:
            print("Нет карточек.")
        else:
            print(f"{'ID':<4} {'Вопрос':<30} {'Ответ':<30} {'Категория':<15} {'Коробка':<8}")
            for c in cards:
                print(f"{c.id:<4} {c.question[:28]:<30} {c.answer[:28]:<30} {c.category:<15} {c.box:<8}")
    elif args.command == "study":
        cards = forge.get_cards_for_review(args.count)
        if not cards:
            print("Нет карточек для повторения.")
            return
        print(f"\n🧠 Начинаем изучение! {len(cards)} карточек.\n")
        for i, card in enumerate(cards, 1):
            print(f"[{i}/{len(cards)}] Вопрос: {card.question}")
            input("Нажмите Enter, чтобы увидеть ответ...")
            print(f"Ответ: {card.answer}")
            while True:
                ans = input("Правильно? (y/n): ").strip().lower()
                if ans in ['y', 'n']:
                    forge.update_card_after_review(card.id, ans == 'y')
                    break
                print("Введите y или n")
            print()
        print("🎯 Изучение завершено!")
    elif args.command == "stats":
        stats = forge.get_statistics()
        print("📊 СТАТИСТИКА")
        print(f"Всего карточек: {stats['total']}")
        print(f"Правильных ответов: {stats['correct']}")
        print(f"Неправильных ответов: {stats['wrong']}")
        print(f"Средняя правильность: {stats['avg_correct']:.2f}%")
        print("Распределение по коробкам (Лейтнер):")
        for box, count in stats['by_box'].items():
            print(f"  Коробка {box}: {count} карточек")
    elif args.command == "edit":
        if forge.edit_card(args.id, args.question, args.answer, args.category):
            print(f"✅ Карточка #{args.id} обновлена")
        else:
            print(f"❌ Карточка #{args.id} не найдена")
    elif args.command == "delete":
        if forge.delete_card(args.id):
            print(f"✅ Карточка #{args.id} удалена")
        else:
            print(f"❌ Карточка #{args.id} не найдена")
    elif args.command == "export":
        forge.export_csv(args.output)
        print(f"Экспортировано в {args.output}")
    elif args.command == "import":
        forge.import_csv(args.file)
        print(f"Импортировано из {args.file}")
    else:
        interactive_mode(forge)

def interactive_mode(forge):
    while True:
        print("\n🧠 FlashForge - Флеш-карточки (интерактивный)")
        print("1. Добавить карточку")
        print("2. Список карточек")
        print("3. Начать изучение")
        print("4. Статистика")
        print("5. Редактировать")
        print("6. Удалить")
        print("7. Экспорт CSV")
        print("8. Импорт CSV")
        print("0. Выход")
        choice = input("Выберите действие: ").strip()
        if choice == "0":
            break
        elif choice == "1":
            q = input("Вопрос: ").strip()
            if not q:
                print("Вопрос обязателен")
                continue
            a = input("Ответ: ").strip()
            if not a:
                print("Ответ обязателен")
                continue
            cat = input("Категория (по умолчанию General): ").strip() or "General"
            card = forge.add_card(q, a, cat)
            print(f"✅ Карточка #{card.id} добавлена")
        elif choice == "2":
            cat = input("Категория (Enter все): ").strip() or None
            cards = forge.get_cards_by_category(cat) if cat else forge.cards
            if not cards:
                print("Нет карточек.")
            else:
                print(f"{'ID':<4} {'Вопрос':<30} {'Ответ':<30} {'Категория':<15} {'Коробка':<8}")
                for c in cards:
                    print(f"{c.id:<4} {c.question[:28]:<30} {c.answer[:28]:<30} {c.category:<15} {c.box:<8}")
        elif choice == "3":
            try:
                count = int(input("Количество карточек (по умолчанию 10): ").strip() or "10")
            except:
                count = 10
            cat = input("Категория (Enter все): ").strip() or None
            cards = forge.get_cards_for_review(count)
            if not cards:
                print("Нет карточек для повторения.")
                continue
            print(f"\n🧠 Начинаем изучение! {len(cards)} карточек.\n")
            for i, card in enumerate(cards, 1):
                print(f"[{i}/{len(cards)}] Вопрос: {card.question}")
                input("Нажмите Enter, чтобы увидеть ответ...")
                print(f"Ответ: {card.answer}")
                while True:
                    ans = input("Правильно? (y/n): ").strip().lower()
                    if ans in ['y', 'n']:
                        forge.update_card_after_review(card.id, ans == 'y')
                        break
                    print("Введите y или n")
                print()
            print("🎯 Изучение завершено!")
        elif choice == "4":
            stats = forge.get_statistics()
            print("📊 СТАТИСТИКА")
            print(f"Всего карточек: {stats['total']}")
            print(f"Правильных ответов: {stats['correct']}")
            print(f"Неправильных ответов: {stats['wrong']}")
            print(f"Средняя правильность: {stats['avg_correct']:.2f}%")
            print("Распределение по коробкам (Лейтнер):")
            for box, count in stats['by_box'].items():
                print(f"  Коробка {box}: {count} карточек")
        elif choice == "5":
            try:
                cid = int(input("ID карточки: ").strip())
            except:
                print("Неверный ID")
                continue
            card = next((c for c in forge.cards if c.id == cid), None)
            if not card:
                print("Карточка не найдена")
                continue
            print("Оставьте пустым, чтобы не менять.")
            new_q = input(f"Вопрос ({card.question}): ").strip()
            new_a = input(f"Ответ ({card.answer}): ").strip()
            new_cat = input(f"Категория ({card.category}): ").strip()
            if forge.edit_card(cid, new_q or None, new_a or None, new_cat or None):
                print("✅ Обновлено")
            else:
                print("❌ Ошибка")
        elif choice == "6":
            try:
                cid = int(input("ID для удаления: ").strip())
            except:
                print("Неверный ID")
                continue
            if forge.delete_card(cid):
                print("✅ Удалено")
            else:
                print("❌ Не найдено")
        elif choice == "7":
            fname = input("Имя файла (CSV): ").strip()
            if not fname:
                fname = "flashcards.csv"
            forge.export_csv(fname)
            print(f"Экспортировано в {fname}")
        elif choice == "8":
            fname = input("Имя файла (CSV): ").strip()
            if not fname:
                print("Укажите файл")
                continue
            forge.import_csv(fname)
            print(f"Импортировано из {fname}")
        else:
            print("Неверный выбор")

# ========== GUI ==========
if GUI_AVAILABLE:
    class FlashForgeGUI:
        def __init__(self, root):
            self.root = root
            self.root.title("🧠 FlashForge - Флеш-карточки")
            self.root.geometry("750x600")
            self.root.resizable(True, True)
            self.forge = FlashForge()
            self.create_widgets()
            self.refresh_list()

        def create_widgets(self):
            main = ttk.Frame(self.root, padding="10")
            main.pack(fill=tk.BOTH, expand=True)

            # Добавление
            add_frame = ttk.LabelFrame(main, text="Добавить карточку")
            add_frame.pack(fill=tk.X, pady=5)
            grid = ttk.Frame(add_frame)
            grid.pack(pady=5, padx=5)
            ttk.Label(grid, text="Вопрос:").grid(row=0, column=0, sticky="w")
            self.q_entry = ttk.Entry(grid, width=25)
            self.q_entry.grid(row=0, column=1, padx=5)
            ttk.Label(grid, text="Ответ:").grid(row=0, column=2, sticky="w")
            self.a_entry = ttk.Entry(grid, width=25)
            self.a_entry.grid(row=0, column=3, padx=5)
            ttk.Label(grid, text="Категория:").grid(row=0, column=4, sticky="w")
            self.cat_entry = ttk.Entry(grid, width=15)
            self.cat_entry.grid(row=0, column=5, padx=5)
            ttk.Button(grid, text="➕ Добавить", command=self.add_card).grid(row=0, column=6, padx=5)

            # Список
            list_frame = ttk.LabelFrame(main, text="Карточки")
            list_frame.pack(fill=tk.BOTH, expand=True, pady=5)
            self.tree = ttk.Treeview(list_frame, columns=("id", "question", "answer", "category", "box"), show="headings")
            self.tree.heading("id", text="ID")
            self.tree.heading("question", text="Вопрос")
            self.tree.heading("answer", text="Ответ")
            self.tree.heading("category", text="Категория")
            self.tree.heading("box", text="Коробка")
            self.tree.column("id", width=40)
            self.tree.column("question", width=200)
            self.tree.column("answer", width=200)
            self.tree.column("category", width=100)
            self.tree.column("box", width=60)
            scroll = ttk.Scrollbar(list_frame, orient=tk.VERTICAL, command=self.tree.yview)
            self.tree.configure(yscrollcommand=scroll.set)
            self.tree.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
            scroll.pack(side=tk.RIGHT, fill=tk.Y)

            # Кнопки
            bottom = ttk.Frame(main)
            bottom.pack(fill=tk.X, pady=5)
            ttk.Button(bottom, text="🧠 Изучать", command=self.study).pack(side=tk.LEFT, padx=5)
            ttk.Button(bottom, text="✏️ Редактировать", command=self.edit_card).pack(side=tk.LEFT, padx=5)
            ttk.Button(bottom, text="🗑 Удалить", command=self.delete_card).pack(side=tk.LEFT, padx=5)
            ttk.Button(bottom, text="📊 Статистика", command=self.show_stats).pack(side=tk.LEFT, padx=5)
            ttk.Button(bottom, text="💾 Экспорт CSV", command=self.export_csv).pack(side=tk.LEFT, padx=5)

        def refresh_list(self):
            self.tree.delete(*self.tree.get_children())
            for c in self.forge.cards:
                self.tree.insert("", tk.END, values=(c.id, c.question, c.answer, c.category, c.box))

        def add_card(self):
            q = self.q_entry.get().strip()
            a = self.a_entry.get().strip()
            cat = self.cat_entry.get().strip() or "General"
            if not q or not a:
                messagebox.showerror("Ошибка", "Вопрос и ответ обязательны")
                return
            self.forge.add_card(q, a, cat)
            self.q_entry.delete(0, tk.END)
            self.a_entry.delete(0, tk.END)
            self.cat_entry.delete(0, tk.END)
            self.refresh_list()

        def get_selected_id(self):
            selected = self.tree.selection()
            if not selected:
                messagebox.showwarning("Выберите карточку")
                return None
            return int(self.tree.item(selected[0])['values'][0])

        def edit_card(self):
            cid = self.get_selected_id()
            if cid is None:
                return
            card = next((c for c in self.forge.cards if c.id == cid), None)
            if not card:
                return
            dialog = tk.Toplevel(self.root)
            dialog.title("Редактировать карточку")
            dialog.geometry("400x250")
            tk.Label(dialog, text="Вопрос:").grid(row=0, column=0, padx=5, pady=5, sticky="w")
            q_ent = tk.Entry(dialog)
            q_ent.insert(0, card.question)
            q_ent.grid(row=0, column=1, padx=5, pady=5)
            tk.Label(dialog, text="Ответ:").grid(row=1, column=0, padx=5, pady=5, sticky="w")
            a_ent = tk.Entry(dialog)
            a_ent.insert(0, card.answer)
            a_ent.grid(row=1, column=1, padx=5, pady=5)
            tk.Label(dialog, text="Категория:").grid(row=2, column=0, padx=5, pady=5, sticky="w")
            cat_ent = tk.Entry(dialog)
            cat_ent.insert(0, card.category)
            cat_ent.grid(row=2, column=1, padx=5, pady=5)
            def save():
                q = q_ent.get().strip()
                a = a_ent.get().strip()
                cat = cat_ent.get().strip()
                if not q or not a:
                    messagebox.showerror("Ошибка", "Вопрос и ответ обязательны")
                    return
                if self.forge.edit_card(cid, q or None, a or None, cat or None):
                    dialog.destroy()
                    self.refresh_list()
                else:
                    messagebox.showerror("Ошибка", "Не удалось обновить")
            tk.Button(dialog, text="Сохранить", command=save).grid(row=3, column=0, columnspan=2, pady=10)

        def delete_card(self):
            cid = self.get_selected_id()
            if cid is not None:
                if messagebox.askyesno("Удаление", f"Удалить карточку #{cid}?"):
                    if self.forge.delete_card(cid):
                        self.refresh_list()

        def study(self):
            cards = self.forge.get_cards_for_review(10)
            if not cards:
                messagebox.showinfo("Изучение", "Нет карточек для повторения")
                return
            win = tk.Toplevel(self.root)
            win.title("🧠 Изучение")
            win.geometry("500x400")
            self.study_idx = 0
            self.study_cards = cards
            self.show_study_card(win)

        def show_study_card(self, win):
            if self.study_idx >= len(self.study_cards):
                tk.Label(win, text="🎯 Изучение завершено!", font=('Arial', 18)).pack(pady=20)
                tk.Button(win, text="Закрыть", command=win.destroy).pack(pady=10)
                return
            card = self.study_cards[self.study_idx]
            for widget in win.winfo_children():
                widget.destroy()
            tk.Label(win, text=f"Карточка {self.study_idx+1}/{len(self.study_cards)}", font=('Arial', 12)).pack(pady=5)
            tk.Label(win, text=f"[{card.category}] Коробка {card.box}", font=('Arial', 10)).pack(pady=5)
            tk.Label(win, text=card.question, font=('Arial', 14), wraplength=450).pack(pady=20)
            answer_shown = False
            def show_answer():
                nonlocal answer_shown
                if answer_shown:
                    return
                answer_shown = True
                ans_label.config(text=f"Ответ: {card.answer}")
                btn_show.config(state='disabled')
                btn_correct.config(state='normal')
                btn_wrong.config(state='normal')
            ans_label = tk.Label(win, text="", font=('Arial', 12))
            ans_label.pack(pady=10)
            btn_show = tk.Button(win, text="Показать ответ", command=show_answer)
            btn_show.pack(pady=5)
            btn_correct = tk.Button(win, text="✅ Правильно", command=lambda: self.answer_study(win, card, True), state='disabled')
            btn_correct.pack(side=tk.LEFT, padx=20, pady=10)
            btn_wrong = tk.Button(win, text="❌ Неправильно", command=lambda: self.answer_study(win, card, False), state='disabled')
            btn_wrong.pack(side=tk.RIGHT, padx=20, pady=10)

        def answer_study(self, win, card, correct):
            self.forge.update_card_after_review(card.id, correct)
            self.study_idx += 1
            self.show_study_card(win)

        def show_stats(self):
            stats = self.forge.get_statistics()
            msg = "📊 СТАТИСТИКА\n\n"
            msg += f"Всего карточек: {stats['total']}\n"
            msg += f"Правильных ответов: {stats['correct']}\n"
            msg += f"Неправильных ответов: {stats['wrong']}\n"
            msg += f"Средняя правильность: {stats['avg_correct']:.2f}%\n\n"
            msg += "Распределение по коробкам (Лейтнер):\n"
            for box, count in stats['by_box'].items():
                msg += f"  Коробка {box}: {count} карточек\n"
            messagebox.showinfo("Статистика", msg)

        def export_csv(self):
            filepath = filedialog.asksaveasfilename(defaultextension=".csv", filetypes=[("CSV", "*.csv")])
            if filepath:
                self.forge.export_csv(filepath)
                messagebox.showinfo("Экспорт", f"Экспортировано в {filepath}")

if __name__ == "__main__":
    cli()
